<Window x:Class="ChronoLog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ChronoLog"
        Title="ChronoLog" Width="1000" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">

    <Window.Resources>
        <local:ContrastForegroundConverter x:Key="ContrastForegroundConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <!-- Make the empty checkbox a bit lighter than the main theme -->
            <Setter Property="Background" Value="#595959"/>
            <Setter Property="BorderBrush" Value="#777"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Border" 
                                Width="22" Height="22" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="5"
                                Cursor="Hand">
                            <!-- Vector Checkmark (Hidden by default) -->
                            <Path x:Name="CheckMark" 
                                  Stroke="White" 
                                  StrokeThickness="3" 
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M 5,11 L 9,15 L 16,6" 
                                  Visibility="Collapsed" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover State -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#999"/>
                                <Setter TargetName="Border" Property="Background" Value="#6A6A6A"/>
                            </Trigger>
                            <!-- Checked State -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <!-- Brighter green and subtle glow to make it pop -->
                                <Setter TargetName="Border" Property="Background" Value="#2ECC71"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#27AE60"/>
                                <Setter TargetName="Border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#2ECC71" Opacity="0.7" BlurRadius="10" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <!-- Disabled/Completed State -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.4"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- MODERN SLIM SCROLLBAR -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="{TemplateBinding Background}">
                            <!-- The Track is the area the thumb moves in -->
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <!-- Buttons for clicking empty space to scroll -->
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="false"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="false"/>
                                </Track.IncreaseRepeatButton>

                                <!-- The actual draggable handle -->
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <!-- Slim, rounded dark grey bar -->
                                                <Border x:Name="ThumbBorder" Background="#555" CornerRadius="4" Margin="2,0" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#888"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="DrawerBorder" Background="#2E2E2E" CornerRadius="5,0,0,5" BorderBrush="#555" BorderThickness="1,0,0,0">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- PANE 1: SIDEBAR (Contexts) -->
            <!-- PANE 1: SIDEBAR (Contexts) -->
            <Border Grid.Column="0" BorderBrush="#555" BorderThickness="0,0,1,0" Margin="0,0,10,0">
                <Grid>
                    <!-- 4 Explicit Rows -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Row 0: Header -->
                        <RowDefinition Height="*"/>
                        <!-- Row 1: The List (Takes remaining space) -->
                        <RowDefinition Height="Auto"/>
                        <!-- Row 2: Add Context Box -->
                        <RowDefinition Height="Auto"/>
                        <!-- Row 3: Settings Button -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="CONTEXTS" Foreground="Gray" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>

                    <ListBox x:Name="ContextList" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="White" SelectionChanged="ContextList_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Margin="0,4" Padding="8" Background="{Binding Color}" SnapsToDevicePixels="True">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <!-- New: Badge Column -->
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Name}" Grid.Column="0" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,5,0" Foreground="{Binding Color, Converter={StaticResource ContrastForegroundConverter}}"/>

                                        <!-- NOTIFICATION BADGE -->
                                        <Border Grid.Column="1" Background="#E53935" CornerRadius="10" MinWidth="20" Height="20" Padding="5,0" Margin="0,0,5,0" Visibility="{Binding BadgeVisibility}">
                                            <TextBlock Text="{Binding TodoCount}" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <Button Grid.Column="2" Content=" x " Background="Transparent" BorderThickness="0" 
                                                Visibility="{Binding DeleteVisibility}" Tag="{Binding Name}" Click="DeleteContext_Click" 
                                                FontSize="12" FontWeight="Bold" Cursor="Hand" Foreground="{Binding Color, Converter={StaticResource ContrastForegroundConverter}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="5,3"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#555555"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3A3A3A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- The Add Context Bar is safely locked to Row 2 -->
                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewContextBox" Grid.Column="0" Height="22" Background="#444" Foreground="White" BorderThickness="0" Padding="2,0" VerticalContentAlignment="Center" KeyDown="NewContextBox_KeyDown"/>
                        <Button Grid.Column="1" Content="+" Width="22" Height="22" Background="#555" Foreground="White" BorderThickness="0" Margin="2,0,0,0" Click="AddContext_Click" Cursor="Hand"/>
                    </Grid>

                    <!-- Settings Button is safely locked to Row 3, pushing it underneath -->
                    <Button Grid.Row="3" Content="⚙ Settings" Foreground="Gray" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Margin="0,15,0,0" FontSize="11" Cursor="Hand" Click="SettingsButton_Click"/>

                </Grid>
            </Border>

            <!-- PANE 2: MAIN STREAM (Feed & Input) -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                    <ListBox x:Name="FeedList" Grid.Row="0" Background="Transparent" BorderThickness="0" Margin="0,0,0,10" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- Col 0: Timestamp -->
                                    <ColumnDefinition Width="*"/>
                                    <!-- Col 1: Text -->
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- Col 2: Checkbox -->
                                </Grid.ColumnDefinitions>

                                <!-- TIMESTAMP (Left) -->
                                <Border Grid.Column="0" Background="{Binding Color}" CornerRadius="4" Padding="6" VerticalAlignment="Top" MinWidth="80">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='dd.MM.'}" Foreground="{Binding Color, Converter={StaticResource ContrastForegroundConverter}}" FontSize="12" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm'}" Foreground="{Binding Color, Converter={StaticResource ContrastForegroundConverter}}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- NOTE TEXT (Middle) -->
                                <TextBlock Grid.Column="1" Text="{Binding Note}" Foreground="White" FontSize="14" TextWrapping="Wrap" VerticalAlignment="Center" Margin="12,0,12,0"/>

                                <!-- CHECKBOX (Right) -->
                                <CheckBox Grid.Column="2" x:Name="TodoCheck" 
                                          Style="{StaticResource ModernCheckBox}"
                                          Visibility="{Binding IsTodo, Converter={StaticResource BoolToVis}}"
                                          IsChecked="{Binding Done, Mode=OneWay}"
                                          Checked="TodoCheckbox_Checked" 
                                          VerticalAlignment="Center" Margin="0,0,5,0"/>
                            </Grid>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Done}" Value="True">
                                    <Setter TargetName="TodoCheck" Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <Grid Grid.Row="1">
                    <TextBox x:Name="InputBox" Height="30" Background="#444" Foreground="White" BorderBrush="#555" 
                             VerticalContentAlignment="Center" Padding="5,0" KeyDown="InputBox_KeyDown"/>
                    <TextBlock x:Name="InputPlaceholder" Text="Select a specific context" Foreground="#AAA" Margin="8,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>