<Window x:Class="ChronoLog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChronoLog" Width="1000" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">

    <Border x:Name="DrawerBorder" Background="#2E2E2E" CornerRadius="5,0,0,5" BorderBrush="#555" BorderThickness="1,0,0,0">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- PANE 1: SIDEBAR (Contexts) -->
            <!-- PANE 1: SIDEBAR (Contexts) -->
            <Border Grid.Column="0" BorderBrush="#555" BorderThickness="0,0,1,0" Margin="0,0,10,0">
                <Grid>
                    <!-- 4 Explicit Rows -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Row 0: Header -->
                        <RowDefinition Height="*"/>
                        <!-- Row 1: The List (Takes remaining space) -->
                        <RowDefinition Height="Auto"/>
                        <!-- Row 2: Add Context Box -->
                        <RowDefinition Height="Auto"/>
                        <!-- Row 3: Settings Button -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="CONTEXTS" Foreground="Gray" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>

                    <ListBox x:Name="ContextList" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="White" SelectionChanged="ContextList_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Name}" Grid.Column="0" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,5,0"/>

                                    <Button Grid.Column="1" Content=" x " Foreground="DimGray" Background="Transparent" BorderThickness="0" 
                                            Visibility="{Binding DeleteVisibility}" Tag="{Binding Name}" Click="DeleteContext_Click" 
                                            FontSize="12" FontWeight="Bold" Cursor="Hand"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="5,3"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#555555"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3A3A3A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- The Add Context Bar is safely locked to Row 2 -->
                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewContextBox" Grid.Column="0" Height="22" Background="#444" Foreground="White" BorderThickness="0" Padding="2,0" VerticalContentAlignment="Center" KeyDown="NewContextBox_KeyDown"/>
                        <Button Grid.Column="1" Content="+" Width="22" Height="22" Background="#555" Foreground="White" BorderThickness="0" Margin="2,0,0,0" Click="AddContext_Click" Cursor="Hand"/>
                    </Grid>

                    <!-- Settings Button is safely locked to Row 3, pushing it underneath -->
                    <Button Grid.Row="3" Content="⚙ Settings" Foreground="Gray" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Margin="0,15,0,0" FontSize="11" Cursor="Hand" Click="SettingsButton_Click"/>

                </Grid>
            </Border>

            <!-- PANE 2: MAIN STREAM (Feed & Input) -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox x:Name="FeedList" Grid.Row="0" Background="Transparent" BorderThickness="0" Margin="0,0,0,10" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="{Binding Timestamp, StringFormat='dd.MM. '}" Foreground="Gray" FontSize="14"/>
                                <TextBlock FontWeight="Bold" Foreground="White" FontSize="14" Text="{Binding Timestamp, StringFormat='HH:mm | '}"/>
                                <TextBlock Text="{Binding Note}" Foreground="White" FontSize="14" TextWrapping="Wrap" Margin="5,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Focusable" Value="False"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <TextBox x:Name="InputBox" Grid.Row="1" Height="30" Background="#444" Foreground="White" BorderBrush="#555" 
                         VerticalContentAlignment="Center" Padding="5,0" KeyDown="InputBox_KeyDown"/>
            </Grid>
        </Grid>
    </Border>
</Window>