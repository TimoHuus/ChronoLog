<Window x:Class="ChronoLog.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chrono-Log Settings" Height="400" Width="350"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen" 
        Background="#2E2E2E" Foreground="White">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="SETTINGS &amp; DEV TOOLS" Foreground="Gray" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Settings & Dev Tools List -->
        <StackPanel Grid.Row="1">

            <!-- DANGER ZONE -->
            <TextBlock Text="DANGER ZONE" Foreground="#AA5555" FontSize="10" FontWeight="Bold" Margin="0,15,0,10"/>

            <Button Content="Wipe Database (Factory Reset)" Background="#552222" Foreground="White" BorderThickness="0" Height="30" Padding="10,0" HorizontalAlignment="Left" Click="WipeDatabase_Click" Cursor="Hand"/>

            <TextBlock Text="Deletes all data and closes the application to reset memory." Foreground="Gray" FontSize="10" Margin="0,5,0,0" FontStyle="Italic"/>
        </StackPanel>

        <!-- A close button at the bottom -->
        <Button Grid.Row="2" Content="Close" Background="#444" Foreground="White" BorderThickness="0" Height="30" Width="80" HorizontalAlignment="Right" Click="CloseButton_Click" Cursor="Hand"/>
    </Grid>
</Window>